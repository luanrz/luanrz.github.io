&lt;tr>
&lt;td style="text-align:center">&lt;a href="#%E4%B8%80%E6%8F%92%E5%85%A5%E6%8E%92%E5%BA%8F">插入排序&lt;/a>&lt;/td>
&lt;td style="text-align:center">O(n²)&lt;/td>
